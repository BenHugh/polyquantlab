# Copy to .env and fill in. Never commit .env.
#
# PolyQuantLab — Polymarket crypto Up/Down data + backtest.
# (Schema-compatible with PolyBackTest's published API for drop-in use.)

# --- ClickHouse ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=stock
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DB=stock

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=stock
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stock

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Polymarket ---
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# --- Binance (spot only — futures geo-blocked from most DC IP ranges) ---
BINANCE_WS_SPOT=wss://stream.binance.com:9443/stream
BINANCE_WS_FUTURES=wss://fstream.binance.com/stream
BINANCE_REST=https://api.binance.com

# --- Bybit V5 (linear futures markPrice — replaces Binance futures) ---
BYBIT_WS_LINEAR=wss://stream.bybit.com/v5/public/linear

# --- Collector ---
COLLECTOR_WORKER_ID=local-1
# Tickers to track (crypto only, same scope as the competitor PolyBackTest).
COLLECTOR_TICKERS=BTC,ETH,SOL
# Re-poll Gamma for new markets every N seconds.
COLLECTOR_DISCOVERY_INTERVAL=300

# --- Alerting (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Stripe (filled in later) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
