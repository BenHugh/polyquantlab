# -----------------------------------------------------------------------------
# Resend: https://shipfa.st/docs/features/emails
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Database URI: https://shipfa.st/docs/features/database
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
# New-format publishable key (sb_publishable_*). Safe in the browser.
# The Supabase clients also fall back to NEXT_PUBLIC_SUPABASE_ANON_KEY
# for backward compatibility with legacy JWT keys.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# New-format secret key (sb_secret_*). SERVER ONLY — never expose to the
# browser. Falls back to SUPABASE_SERVICE_ROLE_KEY for the old format.
SUPABASE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Stripe: https://shipfa.st/docs/features/payments
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# FastAPI bridge — server-to-server calls into our Python API for tier sync
# and API-key management. INTERNAL_API_SECRET MUST match the value set on the
# FastAPI side (collector/config.py:Settings.internal_api_secret). Generate
# with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# -----------------------------------------------------------------------------
FASTAPI_BASE_URL=http://localhost:8000
INTERNAL_API_SECRET=